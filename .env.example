# Escora AI — Environment Variables
# Copy this file to .env and fill in real values.

# Directory where persistent data (learning, uploads, jobs DB) is stored.
# In production (Fly.io) this is typically /data (a mounted volume).
ESCORA_DATA_DIR=./data

# Optional: override the locadoras registry file path.
# ESCORA_LOCADORAS_FILE=./data/locadoras.json
